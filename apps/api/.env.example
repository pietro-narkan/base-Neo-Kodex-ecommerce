# ===== Database =====
DATABASE_URL="postgresql://neokodex:neokodex@localhost:5433/neokodex?schema=public"

# ===== Server =====
PORT=3001
NODE_ENV=development

# ===== Auth =====
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="15m"
REFRESH_SECRET="change-me-to-a-different-long-random-string"
REFRESH_EXPIRES_IN="30d"

# ===== CORS (admin + storefront) =====
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"

# ===== MinIO (media storage) =====
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=neo-kodex-media
MINIO_PUBLIC_URL=http://localhost:9000

# ===== Tax =====
# IVA rate as basis points (1900 = 19.00%)
TAX_RATE_BP=1900

# ===== Providers (Strategy pattern — swap impl sin tocar código) =====
# Payment: manual (transferencia) | webpay (futuro) | flow (futuro)
PAYMENT_PROVIDER=manual

# Email: console (dev, logs) | noop | resend (futuro)
EMAIL_PROVIDER=console

# DTE Chile: mock | openfactura (futuro) | haulmer (futuro)
DTE_PROVIDER=mock

# Shipping: flat (tarifa plana desde Settings) | free | chilexpress (futuro)
SHIPPING_PROVIDER=flat
